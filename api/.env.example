# Copy this file to .env and fill in your values

# Password used to authenticate against the API
APP_PASSWORD=honeymoon

# Secret used to sign/verify bearer tokens (change this in production!)
TOKEN_SECRET=dev-secret-change-me

# Google Maps API key returned to the frontend after auth
MAPS_API_KEY=

# Azure Blob Storage — use connection string for local dev with Azurite,
# or set STORAGE_ACCOUNT and rely on DefaultAzureCredential in production.
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
# STORAGE_ACCOUNT=mystorageaccount

# Blob container names (defaults match the existing setup)
STORAGE_TRIP_CONTAINER=trip
STORAGE_DOCS_CONTAINER=documents
